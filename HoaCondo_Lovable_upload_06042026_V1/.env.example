# HOACONDInsight™ Environment Variables
# Copy this file to .env and fill in your actual values in Lovable > Settings > Environment Variables
# NEVER commit .env to source control — .env is in .gitignore

# ── SUPABASE ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── OPENAI ───────────────────────────────────────────────────
VITE_OPENAI_API_KEY=sk-your_openai_api_key_here

# ── STRIPE ───────────────────────────────────────────────────
# TEST mode: use pk_test_ and sk_test_ keys
# LIVE mode: use pk_live_ and sk_live_ keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# ── RESEND (email delivery) ──────────────────────────────────
VITE_RESEND_API_KEY=re_your_resend_key_here

# ── DEPLOYMENT STATE ─────────────────────────────────────────
# Options: TESTING | LIVE | OFFLINE | READ_ONLY
# Start on TESTING until you are ready to go live
VITE_DEPLOYMENT_STATE=TESTING

# ── FOUNDER PIN ──────────────────────────────────────────────
# CRITICAL: Change this from the default before going live
# Used for deployment state changes and payout authorizations
VITE_FOUNDER_PIN=CHANGE_THIS_BEFORE_GOING_LIVE

# ── PLATFORM INFO (do not change) ───────────────────────────
VITE_APP_NAME=HOACONDInsight
VITE_APP_VERSION=5.2
VITE_COMPANY=Hoa Condo Insight LLC
